#!/sbin/sh
# Minimal Magisk module installer launcher.  All module-specific extraction and
# integrity checks live in customize.sh / verify.sh.
umask 022

OUTFD=$2
ZIPFILE=$3

ui_print() {
  echo "$1"
}

abort_launcher() {
  ui_print "*********************************************************"
  ui_print "! $1"
  ui_print "*********************************************************"
  exit 1
}

[ -n "$ZIPFILE" ] || abort_launcher "Installer did not receive a module ZIP path"
mount /data 2>/dev/null
[ -f /data/adb/magisk/util_functions.sh ] || abort_launcher "Magisk util_functions.sh is unavailable"
. /data/adb/magisk/util_functions.sh
[ -n "$MAGISK_VER_CODE" ] || abort_launcher "Magisk version information is unavailable"
[ "$MAGISK_VER_CODE" -ge 20400 ] || abort_launcher "Magisk 20.4 or newer is required"

install_module
exit 0
